rules_version = '2';

// Prayer Chain security rules.
// Paste these into: Firebase console → Firestore Database → Rules → Publish.
//
// How invite-only is enforced WITHOUT any server code / billing:
//  - To read or write prayers you must be a "member": have a users/{uid} doc.
//  - You can only CREATE your own users/{uid} doc if the inviteCode you submit
//    matches the secret stored at config/invite — and rules read that doc with
//    get(), so the code itself is never exposed to the client.
//  - config/invite is unreadable/unwritable from the app; edit it only in the
//    Firebase console. Change its `code` field any time to rotate the invite.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function isMember() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function validInvite(code) {
      return code == get(/databases/$(database)/documents/config/invite).data.code;
    }

    // Secret invite code — console-only.
    match /config/{doc} {
      allow read, write: if false;
    }

    // Member directory.
    match /users/{uid} {
      allow read: if isMember();
      allow create: if signedIn()
        && request.auth.uid == uid
        && validInvite(request.resource.data.inviteCode)
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.keys().hasOnly(['name', 'email', 'inviteCode', 'createdAt']);
      // Members may rename themselves; nothing else is editable.
      allow update: if request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name']);
      allow delete: if false;
    }

    // Prayer requests — one shared feed. No private/DM collections exist.
    match /prayers/{id} {
      allow read: if isMember();
      allow create: if isMember()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0;
      // The author can edit/answer/delete their own request; any member may
      // only touch the "I prayed" list or the comment counter.
      allow update: if isMember() && (
        resource.data.uid == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['prayedBy', 'commentCount'])
      );
      allow delete: if isMember() && resource.data.uid == request.auth.uid;

      // Updates / encouragement on a request.
      match /comments/{cid} {
        allow read: if isMember();
        allow create: if isMember()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.body is string
          && request.resource.data.body.size() > 0;
        allow update: if false;
        allow delete: if isMember()
          && (resource.data.uid == request.auth.uid
              || get(/databases/$(database)/documents/prayers/$(id)).data.uid == request.auth.uid);
      }
    }
  }
}
